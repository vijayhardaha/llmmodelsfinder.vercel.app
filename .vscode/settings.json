{
  // ======================================================================
  // VS Code Workspace Settings
  // ======================================================================
  // Purpose: Configure formatter, ESLint, and editor behavior for consistency
  // Docs:    https://code.visualstudio.com/docs/getstarted/settings
  // ======================================================================

  // ---- Formatting & Saving ----
  // Use Prettier as the master formatter for this project
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // We disable `formatOnSave` because ESLint code actions handle formatting
  "editor.formatOnSave": false,

  "editor.codeActionsOnSave": {
    // Automatically fix lint errors and trigger Prettier on every save
    "source.fixAll.eslint": "explicit"
  },

  // ---- Linter Integration ----
  // Allow ESLint to handle formatting (via Prettier plugin)
  "eslint.enable": true,
  "eslint.format.enable": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],

  // ---- File Associations & Tailwind CSS ----
  // Associate CSS files with Tailwind CSS language mode for enhanced syntax highlighting
  "files.associations": { "*.css": "tailwindcss" },

  // Define custom class attributes for Tailwind CSS IntelliSense
  "tailwindCSS.classAttributes": ["class", "className", "theme"],

  // Enable experimental class regex patterns for Tailwind utilities in custom functions
  // Supports: twMerge() and createTheme() utility functions
  "tailwindCSS.experimental.classRegex": [
    ["twMerge\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["createTheme(?:<\\w+>)?\\s*\\(([^)]*)\\)", "{?\\s?[\\w].*:\\s*?[\"'`]([^\"'`]*).*?,?\\s?}?"]
  ]
}
